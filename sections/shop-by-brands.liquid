{{ 'section-shop-by-brands.css' | asset_url | stylesheet_tag }}

{%- style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {% if section.settings.enable_border %}
  .shop-by-brands-{{ section.id }} .brand-item {
    border: 1px solid var(--color-foreground-10);
    border-radius: {{ section.settings.border_radius }}px;
  }
  {% endif %}
  
  .shop-by-brands-{{ section.id }} .brand-item {
    padding: {{ section.settings.logo_padding }}px;
  }
  
  .shop-by-brands-{{ section.id }} .brand-item .brand-image {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    border-radius: {{ section.settings.image_radius }}px;
  }
  
  .shop-by-brands-{{ section.id }} .brand-item .brand-placeholder {
    height: {{ section.settings.logo_height }}px;
    border-radius: {{ section.settings.image_radius }}px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width isolate section-{{ section.id }}-padding">
    
    {%- if section.settings.title != blank or section.settings.text != blank -%}
      <div class="brands-header brands-header--{{ section.settings.content_alignment }}">
        {%- if section.settings.title != blank -%}
          <h2
            id="SectionHeading-{{ section.id }}"
            class="brands-title {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          >
            {{ section.settings.title }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="brands-text{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="brands-wrapper shop-by-brands-{{ section.id }}">
        
        {%- if section.settings.enable_carousel -%}
          <div class="brands-carousel-wrapper">
            <button class="brands-arrow brands-arrow--prev" aria-label="Previous slide">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            
            <div class="brands-carousel" id="BrandsCarousel-{{ section.id }}">
              {%- for block in section.blocks -%}
                <div class="brand-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="brand-link" {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
                  {%- endif -%}
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 300 }}"
                      alt="{{ block.settings.image.alt | escape }}"
                      loading="lazy"
                      class="brand-image"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {%- else -%}
                    <div class="brand-placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
            
            <button class="brands-arrow brands-arrow--next" aria-label="Next slide">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
          
          {%- if section.settings.navigation_style != 'arrows' -%}
            <div class="brands-dots" id="BrandsDots-{{ section.id }}"></div>
          {%- endif -%}
          
        {%- else -%}
          <div class="brands-grid brands-grid--{{ section.settings.columns_mobile }}-col-tablet brands-grid--{{ section.settings.columns_desktop }}-col-desktop">
            {%- for block in section.blocks -%}
              <div class="brand-item" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="brand-link" {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 300 }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    loading="lazy"
                    class="brand-image"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  <div class="brand-placeholder">
                    {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                  </div>
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        
      </div>
    {%- endif -%}
  </div>
</div>

{%- if section.settings.enable_carousel and section.blocks.size > 1 -%}
<script>
(function() {
  const section = document.querySelector('#BrandsCarousel-{{ section.id }}');
  if (!section) return;

  const wrapper = section.closest('.brands-carousel-wrapper');
  const prevBtn = wrapper.querySelector('.brands-arrow--prev');
  const nextBtn = wrapper.querySelector('.brands-arrow--next');
  const dotsContainer = document.querySelector('#BrandsDots-{{ section.id }}');
  
  const items = section.querySelectorAll('.brand-item');
  const totalItems = items.length;
  const desktopVisible = {{ section.settings.visible_on_desktop | default: 5 }};
  const mobileVisible = {{ section.settings.visible_on_mobile | default: 2 }};
  const autoPlayDelay = {{ section.settings.autoplay_delay | default: 3000 }};
  const navStyle = '{{ section.settings.navigation_style | default: 'arrows' }}';
  
  let currentIndex = 0;
  let intervalId = null;
  let isAnimating = false;

  function getVisibleCount() {
    if (window.innerWidth <= 749) {
      return mobileVisible;
    }
    return desktopVisible;
  }

  function getItemWidth() {
    const containerWidth = section.offsetWidth;
    const visible = getVisibleCount();
    const gap = {{ section.settings.carousel_gap | default: 24 }};
    return ((containerWidth - (gap * (visible - 1))) / visible);
  }

  function getMaxIndex() {
    return Math.max(0, totalItems - getVisibleCount());
  }

  function updateCarousel() {
    if (isAnimating) return;
    isAnimating = true;
    
    const visible = getVisibleCount();
    const itemWidth = getItemWidth();
    const gap = {{ section.settings.carousel_gap | default: 24 }};
    const translateX = -(currentIndex * (itemWidth + gap));
    
    section.style.transition = 'transform 0.5s ease';
    section.style.transform = `translateX(${translateX}px)`;
    
    // Update items width
    items.forEach((item, index) => {
      item.style.flex = `0 0 ${itemWidth}px`;
      item.style.maxWidth = `${itemWidth}px`;
    });
    
    // Update dots
    if (dotsContainer && (navStyle === 'dots' || navStyle === 'both')) {
      const dots = dotsContainer.querySelectorAll('.brand-dot');
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentIndex);
      });
    }
    
    setTimeout(() => {
      isAnimating = false;
    }, 500);
  }

  function goToSlide(index) {
    const maxIndex = getMaxIndex();
    currentIndex = Math.max(0, Math.min(index, maxIndex));
    updateCarousel();
  }

  function nextSlide() {
    const maxIndex = getMaxIndex();
    currentIndex = currentIndex >= maxIndex ? 0 : currentIndex + 1;
    updateCarousel();
  }

  function prevSlide() {
    const maxIndex = getMaxIndex();
    currentIndex = currentIndex <= 0 ? maxIndex : currentIndex - 1;
    updateCarousel();
  }

  function startAutoPlay() {
    if (autoPlayDelay > 0) {
      intervalId = setInterval(nextSlide, autoPlayDelay);
    }
  }

  function stopAutoPlay() {
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = null;
    }
  }

  // Create dots
  if (dotsContainer && (navStyle === 'dots' || navStyle === 'both')) {
    const maxIndex = getMaxIndex();
    for (let i = 0; i <= maxIndex; i++) {
      const dot = document.createElement('button');
      dot.className = 'brand-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
      dot.addEventListener('click', () => {
        stopAutoPlay();
        goToSlide(i);
        startAutoPlay();
      });
      dotsContainer.appendChild(dot);
    }
  }

  // Arrow events
  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      stopAutoPlay();
      prevSlide();
      startAutoPlay();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      stopAutoPlay();
      nextSlide();
      startAutoPlay();
    });
  }

  // Pause on hover
  if (wrapper) {
    wrapper.addEventListener('mouseenter', stopAutoPlay);
    wrapper.addEventListener('mouseleave', startAutoPlay);
  }

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;

  section.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
    stopAutoPlay();
  }, { passive: true });

  section.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
    startAutoPlay();
  }, { passive: true });

  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        nextSlide();
      } else {
        prevSlide();
      }
    }
  }

  // Initial setup
  setTimeout(updateCarousel, 100);
  startAutoPlay();

  // Handle resize
  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      currentIndex = 0;
      updateCarousel();
    }, 250);
  });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Shop by Brands",
  "tag": "section",
  "class": "section shop-by-brands",
  "max_blocks": 20,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Shop by Brands",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description text"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Content alignment"
    },
    {
      "type": "header",
      "content": "Brand Settings"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 40,
      "max": 200,
      "step": 10,
      "default": 100,
      "unit": "px",
      "label": "Logo height"
    },
    {
      "type": "range",
      "id": "logo_padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16,
      "unit": "px",
      "label": "Logo padding"
    },
    {
      "type": "checkbox",
      "id": "enable_border",
      "default": true,
      "label": "Enable border"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8,
      "unit": "px",
      "label": "Border radius"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Image corner radius"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "default": true,
      "label": "Enable carousel"
    },
    {
      "type": "range",
      "id": "carousel_gap",
      "min": 0,
      "max": 48,
      "step": 4,
      "default": 24,
      "unit": "px",
      "label": "Gap between logos"
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5,
      "label": "Columns"
    },
    {
      "type": "range",
      "id": "visible_on_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5,
      "label": "Visible items in carousel"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Columns (grid mode)"
    },
    {
      "type": "range",
      "id": "visible_on_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Visible items in carousel"
    },
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "default": 3000,
      "unit": "ms",
      "label": "Autoplay delay"
    },
    {
      "type": "select",
      "id": "navigation_style",
      "options": [
        { "value": "arrows", "label": "Arrows only" },
        { "value": "dots", "label": "Dots only" },
        { "value": "both", "label": "Both arrows and dots" }
      ],
      "default": "both",
      "label": "Navigation style"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "default": false,
          "label": "Open link in new tab"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Brands",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
