{{ 'section-shop-by-brands.css' | asset_url | stylesheet_tag }}

{%- style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .shop-by-brands-{{ section.id }} .brand-item {
    {% if section.settings.logo_height != blank %}
      height: {{ section.settings.logo_height }}px;
    {% else %}
      height: 100px;
    {% endif %}
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width isolate section-{{ section.id }}-padding">
    {%- if section.settings.title != blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        <h2
          id="SectionHeading-{{ section.id }}"
          class="title {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        >
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="brands-text{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.text }}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="brands-wrapper shop-by-brands-{{ section.id }}">
        {%- if section.settings.mobile_layout == 'carousel' -%}
          <div class="brands-carousel" id="BrandsCarousel-{{ section.id }}">
            {%- for block in section.blocks -%}
              <div class="brand-item" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="brand-link">
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 200 }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    loading="lazy"
                    class="brand-image"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  <div class="brand-placeholder">
                    {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                  </div>
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="brands-grid brands-grid--{{ section.settings.columns_mobile }}-col-mobile brands-grid--{{ section.settings.columns_desktop }}-col-desktop">
            {%- for block in section.blocks -%}
              <div class="brand-item" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="brand-link">
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 200 }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    loading="lazy"
                    class="brand-image"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  <div class="brand-placeholder">
                    {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                  </div>
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{%- if section.settings.mobile_layout == 'carousel' and section.blocks.size > 1 -%}
<script>
  (function() {
    const section = document.querySelector('#BrandsCarousel-{{ section.id }}');
    if (!section) return;

    const items = section.querySelectorAll('.brand-item');
    let currentIndex = 0;
    let intervalId = null;
    const autoPlayDelay = {{ section.settings.autoplay_delay | default: 3000 }};
    const desktopVisible = {{ section.settings.visible_on_desktop | default: 5 }};
    const mobileVisible = {{ section.settings.visible_on_mobile | default: 2 }};
    const navStyle = '{{ section.settings.navigation_style | default: 'arrows' }}';

    function getVisibleCount() {
      if (window.innerWidth <= 768) {
        return mobileVisible;
      }
      return desktopVisible;
    }

    function getItemWidth() {
      const containerWidth = section.offsetWidth - 80; // Subtract padding
      const visible = getVisibleCount();
      const gap = 16; // 1rem gap
      return (containerWidth / visible) - gap;
    }

    function updateCarousel() {
      const visible = getVisibleCount();
      const itemWidth = getItemWidth();
      
      items.forEach((item, index) => {
        if (index >= currentIndex && index < currentIndex + visible) {
          item.style.display = 'flex';
          item.style.width = itemWidth + 'px';
        } else {
          item.style.display = 'none';
        }
      });
      
      // Update dots if they exist
      const dots = section.parentElement.querySelectorAll('.brand-dot');
      dots.forEach((dot, index) => {
        if (index >= currentIndex && index < currentIndex + visible) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    }

    function nextSlide() {
      const visible = getVisibleCount();
      const maxIndex = Math.max(0, items.length - visible);
      currentIndex = (currentIndex + 1) % (maxIndex + 1);
      updateCarousel();
    }

    function prevSlide() {
      const visible = getVisibleCount();
      const maxIndex = Math.max(0, items.length - visible);
      currentIndex = (currentIndex - 1 + maxIndex + 1) % (maxIndex + 1);
      updateCarousel();
    }

    // Create navigation container
    const navContainer = document.createElement('div');
    navContainer.className = 'brands-nav';
    
    // Add arrows if selected
    if (navStyle === 'arrows' || navStyle === 'both') {
      navContainer.innerHTML += `
        <button class="brands-nav-btn brands-prev" aria-label="Previous">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
      `;
    }
    
    // Add dots if selected
    if (navStyle === 'dots' || navStyle === 'both') {
      const dotsContainer = document.createElement('div');
      dotsContainer.className = 'brands-dots';
      items.forEach((_, index) => {
        const dot = document.createElement('span');
        dot.className = 'brand-dot';
        dot.setAttribute('data-index', index);
        dot.addEventListener('click', function() {
          currentIndex = index;
          clearInterval(intervalId);
          updateCarousel();
          intervalId = setInterval(nextSlide, autoPlayDelay);
        });
        dotsContainer.appendChild(dot);
      });
      navContainer.appendChild(dotsContainer);
    }
    
    // Add next arrow if arrows are selected (after dots)
    if (navStyle === 'arrows' || navStyle === 'both') {
      navContainer.innerHTML += `
        <button class="brands-nav-btn brands-next" aria-label="Next">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      `;
    }
    
    section.parentElement.appendChild(navContainer);

    // Add event listeners for arrows
    const prevBtn = navContainer.querySelector('.brands-prev');
    const nextBtn = navContainer.querySelector('.brands-next');

    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        clearInterval(intervalId);
        prevSlide();
        intervalId = setInterval(nextSlide, autoPlayDelay);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        clearInterval(intervalId);
        nextSlide();
        intervalId = setInterval(nextSlide, autoPlayDelay);
      });
    }

    // Pause on hover
    section.addEventListener('mouseenter', function() {
      clearInterval(intervalId);
    });

    section.addEventListener('mouseleave', function() {
      intervalId = setInterval(nextSlide, autoPlayDelay);
    });

    // Initial setup
    updateCarousel();
    intervalId = setInterval(nextSlide, autoPlayDelay);

    // Handle resize
    let resizeTimeout;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(function() {
        currentIndex = 0;
        updateCarousel();
      }, 250);
    });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Shop by Brands",
  "tag": "section",
  "class": "section shop-by-brands",
  "max_blocks": 20,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Shop by Brands",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description text"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 50,
      "max": 200,
      "step": 10,
      "default": 100,
      "unit": "px",
      "label": "Logo height"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5,
      "label": "Number of columns (desktop)"
    },
    {
      "type": "range",
      "id": "visible_on_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5,
      "label": "Visible items in carousel (desktop)"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "carousel",
          "label": "Carousel"
        }
      ],
      "default": "grid",
      "label": "Mobile layout"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Number of columns (mobile grid)"
    },
    {
      "type": "range",
      "id": "visible_on_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Visible items in carousel (mobile)"
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 1000,
      "max": 7000,
      "step": 500,
      "default": 3000,
      "unit": "ms",
      "label": "Autoplay delay"
    },
    {
      "type": "select",
      "id": "navigation_style",
      "options": [
        {
          "value": "arrows",
          "label": "Arrows"
        },
        {
          "value": "dots",
          "label": "Dots"
        },
        {
          "value": "both",
          "label": "Both"
        }
      ],
      "default": "arrows",
      "label": "Navigation style"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Logo link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Brands",
      "blocks": [
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        }
      ]
    }
  ]
}
{% endschema %}
