<section class="slider-section">
  <div class="slider-container" id="slider-{{ section.id }}">
    
    {%- for block in section.blocks -%}
    <div class="slide-item" data-slide="{{ forloop.index0 }}">
      
      {%- case block.type -%}
      {%- when 'video' -%}
        {% if block.settings.video != blank %}
        <div class="desktop-video">
          {{ block.settings.video | video_tag: image_size: '1920x', autoplay: true, muted: true, loop: true, controls: false }}
        </div>
        {% endif %}
        {% if block.settings.mobile_video != blank %}
        <div class="mobile-video">
          {{ block.settings.mobile_video | video_tag: image_size: '750x', autoplay: true, muted: true, loop: true, controls: false }}
        </div>
        {% endif %}
        {% if block.settings.video == blank and block.settings.mobile_video == blank %}
        <div class="placeholder-img">
          {{ 'video' | placeholder_svg_tag: 'placeholder' }}
        </div>
        {% endif %}
      
      {%- when 'slide' -%}
        {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}">
        {% endif %}
        
        {% if block.settings.image != blank %}
        <picture>
          {% if block.settings.mobile_image != blank %}
          <source media="(max-width: 768px)" srcset="{{ block.settings.mobile_image | image_url: width: 750 }}">
          {% endif %}
          <img src="{{ block.settings.image | image_url: width: 1920 }}" alt="" class="slide-image">
        </picture>
        {% endif %}
        
        {% if block.settings.image == blank and block.settings.mobile_image == blank %}
        <div class="placeholder-img">
          {{ 'image' | placeholder_svg_tag: 'placeholder' }}
        </div>
        {% endif %}
        
        {% if block.settings.link != blank %}
        </a>
        {% endif %}
      {%- endcase -%}
      
      {% if block.settings.title != blank or block.settings.text != blank %}
      <div class="slide-content">
        {% if block.settings.title != blank %}
        <h2>{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.text != blank %}
        <p>{{ block.settings.text }}</p>
        {% endif %}
        {% if block.settings.btn_text != blank %}
        <a href="{{ block.settings.link }}" class="btn">{{ block.settings.btn_text }}</a>
        {% endif %}
      </div>
      {% endif %}
      
    </div>
    {%- endfor -%}
    
  </div>
  
  <button class="arrow-prev">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>
  <button class="arrow-next">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>
  
  <div class="slider-dots">
    {%- for block in section.blocks -%}
    <span class="dot" data-slide="{{ forloop.index0 }}"></span>
    {%- endfor -%}
  </div>
  
</section>

<style>
.slider-section {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.slider-container {
  position: relative;
  width: 100%;
}

.slide-item {
  display: none;
  width: 100%;
}

.slide-item:first-child {
  display: block;
}

.slide-item img,
.slide-item picture img {
  width: 100%;
  height: auto;
  display: block;
}

.slide-item picture {
  display: block;
}

.slide-item video {
  width: 100%;
  height: auto;
  display: block;
}

.slide-item .desktop-video video,
.slide-item .desktop-video video source {
  width: 100%;
  height: auto;
  display: block;
}

.slide-item .mobile-video {
  display: none;
}

.slide-item .mobile-video video,
.slide-item .mobile-video video source {
  width: 100%;
  height: auto;
  display: block;
}

@media (max-width: 768px) {
  .slide-item .desktop-video {
    display: none;
  }
  .slide-item .mobile-video {
    display: block;
  }
}

.slide-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  color: #fff;
  z-index: 10;
}

.slide-content h2 {
  font-size: 48px;
  margin: 0 0 20px;
  color: #fff;
}

.slide-content p {
  font-size: 20px;
  margin: 0 0 30px;
  color: #fff;
}

.slide-content .btn {
  display: inline-block;
  padding: 15px 40px;
  background: #fff;
  color: #000;
  text-decoration: none;
  font-weight: bold;
}

.arrow-prev,
.arrow-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.5);
  color: #fff;
  border: none;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  cursor: pointer;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-prev { left: 20px; }
.arrow-next { right: 20px; }

.slider-dots {
  position: absolute;
  bottom: 20px;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 10px;
  z-index: 20;
}

.dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  border: 2px solid #fff;
  cursor: pointer;
}

.dot.active {
  background: #fff;
}

.placeholder-img {
  background: #f0f0f0;
  height: 500px;
}
</style>

<script>
(function(){
  var section = document.querySelector('.slider-section');
  var slides = section.querySelectorAll('.slide-item');
  var dots = section.querySelectorAll('.dot');
  var prev = section.querySelector('.arrow-prev');
  var next = section.querySelector('.arrow-next');
  var count = slides.length;
  var current = 0;
  var timer;

  if(count === 0) return;

  function show(index) {
    slides.forEach(function(s){ s.style.display = 'none'; });
    dots.forEach(function(d){ d.classList.remove('active'); });
    slides[index].style.display = 'block';
    dots[index].classList.add('active');
    current = index;
  }

  function goNext() {
    show((current + 1) % count);
  }

  function goPrev() {
    show((current - 1 + count) % count);
  }

  next.addEventListener('click', function(){
    goNext();
    resetTimer();
  });

  prev.addEventListener('click', function(){
    goPrev();
    resetTimer();
  });

  dots.forEach(function(dot, i){
    dot.addEventListener('click', function(){
      show(i);
      resetTimer();
    });
  });

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(goNext, 5000);
  }

  show(0);
  timer = setInterval(goNext, 5000);
})();
</script>

