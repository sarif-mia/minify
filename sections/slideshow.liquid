{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

<style>
  /* Full viewport width slideshow */
  .slideshow-section {
    width: 100%;
    max-width: 100vw;
    overflow: hidden;
    position: relative;
  }
  
  .slideshow-section .banner {
    width: 100%;
    max-width: 100vw;
  }
  
  .slideshow-section .banner__media {
    width: 100%;
    height: 100%;
    min-height: 50vh;
  }
  
  .slideshow-section .banner__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  /* Desktop height */
  @media screen and (min-width: 750px) {
    .slideshow-section .banner__media {
      min-height: 700px;
    }
  }
  
  /* Mobile height */
  @media screen and (max-width: 749px) {
    .slideshow-section .banner__media {
      min-height: 500px;
    }
  }
  
  /* Dots on right side */
  .slideshow__controls {
    position: absolute !important;
    bottom: 30px !important;
    right: 30px !important;
    left: auto !important;
    transform: none !important;
    z-index: 10;
    background: rgba(0, 0, 0, 0.4) !important;
    backdrop-filter: blur(10px);
    border-radius: 30px !important;
    padding: 12px 20px !important;
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  /* Style for dots */
  .slideshow__control-wrapper {
    display: flex !important;
    justify-content: center;
    gap: 8px;
  }
  
  .slider-counter__link {
    padding: 5px !important;
  }
  
  .slider-counter__link .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.6);
    transition: all 0.3s ease;
    display: block;
  }
  
  .slider-counter__link--active .dot,
  .slider-counter__link:hover .dot {
    background: #ffffff;
    border-color: #ffffff;
    transform: scale(1.2);
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
  }
  
  /* Mobile */
  @media screen and (max-width: 749px) {
    .slideshow__controls {
      bottom: 15px !important;
      right: 15px !important;
      left: auto !important;
      transform: none !important;
      padding: 8px 15px !important;
      gap: 8px !important;
    }
    
    .slider-counter__link .dot {
      width: 8px;
      height: 8px;
    }
  }
  
  /* Hide text content */
  .slideshow__text-wrapper,
  .banner__content,
  .slideshow__text,
  .banner__box {
    display: none !important;
  }
</style>

<slideshow-component
  class="slideshow-section slider-mobile-gutter"
  role="region"
  aria-roledescription="Slideshow"
  aria-label="Image Slideshow"
>
  <div
    class="slideshow banner banner--large grid grid--1-col slider slider--everywhere"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="true"
    data-speed="5"
  >
    {%- for block in section.blocks -%}
      {%- assign slide_link = block.settings.link -%}
      <a href="{{ slide_link }}" class="slideshow__slide-link" {% if slide_link == blank %}style="pointer-events: none;"{% endif %}>
      <div
        class="slideshow__slide grid__item grid--1-col slider__slide"
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="Slide"
        aria-label="{{ forloop.index }} of {{ forloop.length }}"
        tabindex="-1"
      >
        <div class="slideshow__media banner__media media">
          {%- if block.settings.image -%}
            {%- liquid
              assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
              assign sizes = '100vw'
              assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              assign fetch_priority = 'auto'
              if section.index == 1
                assign fetch_priority = 'high'
              endif
            -%}
            {%- if block.settings.mobile_image != blank -%}
              <picture>
                <source
                  media="(max-width: 749px)"
                  srcset="{{ block.settings.mobile_image | image_url: width: 750 }}"
                >
                <source
                  media="(min-width: 750px)"
                  srcset="{{ block.settings.image | image_url: width: 3840 }}"
                >
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority, class: 'slideshow__image'
                }}
              </picture>
            {%- else -%}
              {{
                block.settings.image
                | image_url: width: 3840
                | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority, class: 'slideshow__image'
              }}
            {%- endif -%}
          {%- else -%}
            {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
            {%- if placeholder_slide == 1 -%}
              {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
      </a>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
  <div class="slideshow__controls">
    <div class="slideshow__control-wrapper">
      {%- for block in section.blocks -%}
        <button
          class="slider-counter__link slider-counter__link--dots link{% if forloop.index == 1 %} slider-counter__link--active{% endif %}"
          aria-label="Go to slide {{ forloop.index }}"
          aria-controls="Slider-{{ section.id }}"
        >
          <span class="dot"></span>
        </button>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}
</slideshow-component>

<style>
  .slideshow__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .slideshow__image {
    width: 100%;
    height: 100%;
    object-fit: cover !important;
    object-position: center center;
  }
  
  /* Clickable slide link */
  .slideshow__slide-link {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    cursor: pointer;
  }
  
  /* Full width slider */
  #Slider-{{ section.id }}.banner {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
</style>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "Image Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "slide_height",
      "options": [
        {
          "value": "small",
          "label": "Small (400px)"
        },
        {
          "value": "medium",
          "label": "Medium (500px)"
        },
        {
          "value": "large",
          "label": "Large (700px)"
        },
        {
          "value": "fullscreen",
          "label": "Fullscreen"
        }
      ],
      "default": "large",
      "label": "Slide height"
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide Link (click to open URL)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
