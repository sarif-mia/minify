{{ 'component-slider.css' | asset_url | stylesheet_tag }}

<style>
  .slideshow-section {
    width: 100%;
    max-width: 100vw;
    overflow: hidden;
    position: relative;
  }

  .slideshow {
    display: flex;
    width: 100%;
    height: 600px;
    overflow: hidden;
  }

  @media (max-width: 749px) {
    .slideshow {
      height: 400px;
    }
  }

  .slideshow__slide {
    min-width: 100%;
    height: 100%;
    position: relative;
  }

  .slideshow__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slideshow__image--mobile {
    display: none;
  }

  @media (max-width: 749px) {
    .slideshow__image--desktop {
      display: none;
    }
    .slideshow__image--mobile {
      display: block;
    }
  }

  .slideshow__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Navigation Dots */
  .slideshow__nav {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .slideshow__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: 2px solid #fff;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .slideshow__dot:hover {
    background: rgba(255, 255, 255, 0.8);
  }

  .slideshow__dot.active {
    background: #fff;
    transform: scale(1.2);
  }

  /* Arrow Buttons */
  .slideshow__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .slideshow__arrow:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .slideshow__arrow svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: #fff;
    stroke-width: 2;
  }

  .slideshow__arrow--prev {
    left: 20px;
  }

  .slideshow__arrow--next {
    right: 20px;
  }
</style>

<div class="slideshow-section">
  <div class="slideshow" id="Slideshow-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="slideshow__slide" data-index="{{ forloop.index0 }}">
        {%- if block.settings.image != blank -%}
          {%- assign desktop_image = block.settings.image -%}
          {%- assign mobile_image = block.settings.mobile_image -%}
          {%- assign slide_link = block.settings.link -%}
          
          {%- if slide_link != blank -%}
            <a href="{{ slide_link }}" class="slideshow__link">
          {%- endif -%}
          
          {%- if mobile_image != blank -%}
            <img 
              src="{{ mobile_image | image_url: width: 800 }}" 
              alt="{{ mobile_image.alt | escape }}"
              class="slideshow__image slideshow__image--mobile"
              {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
            >
            <img 
              src="{{ desktop_image | image_url: width: 1920 }}" 
              alt="{{ desktop_image.alt | escape }}"
              class="slideshow__image slideshow__image--desktop"
              {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
            >
          {%- else -%}
            <img 
              src="{{ desktop_image | image_url: width: 1920 }}" 
              alt="{{ desktop_image.alt | escape }}"
              class="slideshow__image"
              {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
            >
          {%- endif -%}
          
          {%- if slide_link != blank -%}
            </a>
          {%- endif -%}
        
        {%- else -%}
          <div style="width:100%;height:100%;background:#f5f5f5;display:flex;align-items:center;justify-content:center;">
            <span>Add Image {{ forloop.index }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="slideshow__arrow slideshow__arrow--prev" aria-label="Previous slide" type="button">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <button class="slideshow__arrow slideshow__arrow--next" aria-label="Next slide" type="button">
      <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>

    <div class="slideshow__nav">
      {%- for block in section.blocks -%}
        <button 
          class="slideshow__dot{% if forloop.first %} active{% endif %}" 
          data-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
          type="button"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
  (function() {
    const wrapper = document.querySelector('.slideshow-section');
    if (!wrapper) return;
    
    const slideshow = wrapper.querySelector('.slideshow');
    const slides = slideshow.querySelectorAll('.slideshow__slide');
    const dots = wrapper.querySelectorAll('.slideshow__dot');
    const prevBtn = wrapper.querySelector('.slideshow__arrow--prev');
    const nextBtn = wrapper.querySelector('.slideshow__arrow--next');
    
    if (slides.length === 0) return;
    
    let currentIndex = 0;
    const totalSlides = slides.length;
    const autoRotate = {{ section.settings.auto_rotate }};
    const speed = {{ section.settings.change_slides_speed }} * 1000;
    let autoplayInterval;

    // Set initial position
    slideshow.style.transition = 'transform 0.5s ease-in-out';

    function goToSlide(index) {
      currentIndex = index;
      if (currentIndex >= totalSlides) currentIndex = 0;
      if (currentIndex < 0) currentIndex = totalSlides - 1;
      
      slideshow.style.transform = 'translateX(-' + (currentIndex * 100) + '%)';
      
      dots.forEach(function(dot, i) {
        dot.classList.toggle('active', i === currentIndex);
      });
    }

    function nextSlide() {
      goToSlide(currentIndex + 1);
    }

    function startAutoplay() {
      if (autoRotate && totalSlides > 1) {
        autoplayInterval = setInterval(nextSlide, speed);
      }
    }

    function stopAutoplay() {
      clearInterval(autoplayInterval);
    }

    // Arrow navigation
    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        stopAutoplay();
        goToSlide(currentIndex - 1);
        startAutoplay();
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        stopAutoplay();
        goToSlide(currentIndex + 1);
        startAutoplay();
      });
    }

    // Dot navigation
    dots.forEach(function(dot, index) {
      dot.addEventListener('click', function() {
        stopAutoplay();
        goToSlide(index);
        startAutoplay();
      });
    });

    // Touch/swipe support
    let touchStartX = 0;
    
    slideshow.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
    }, {passive: true});
    
    slideshow.addEventListener('touchend', function(e) {
      const touchEndX = e.changedTouches[0].clientX;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > 50) {
        stopAutoplay();
        if (diff > 0) {
          goToSlide(currentIndex + 1);
        } else {
          goToSlide(currentIndex - 1);
        }
        startAutoplay();
      }
    }, {passive: true});

    // Start autoplay
    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Basic Slideshow",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Basic Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
