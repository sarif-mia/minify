<section class="pro-slider">

<div class="slides">

{% for block in section.blocks %}

<div class="slide">

{% if block.settings.link != blank %}
<a href="{{ block.settings.link }}">
{% endif %}

<picture>

{% if block.settings.mobile_image != blank %}
<source media="(max-width:749px)" srcset="{{ block.settings.mobile_image | image_url: width: 750 }}">
{% endif %}

{% if block.settings.image != blank %}
<img src="{{ block.settings.image | image_url: width: 2000 }}" alt="" loading="lazy">
{% endif %}

</picture>

{% if block.settings.link != blank %}
</a>
{% endif %}

</div>

{% endfor %}

</div>

<button class="slider-prev">❮</button>
<button class="slider-next">❯</button>

<div class="slider-dots"></div>

</section>


<style>

.pro-slider{
position:relative;
width:100%;
overflow:hidden;
}

.slides{
position:relative;
}

.slide{
display:none;
}

.slide img{
width:100%;
display:block;
}

.slide:first-child{
display:block;
}

.slider-prev,
.slider-next{
position:absolute;
top:50%;
transform:translateY(-50%);
background:rgba(0,0,0,0.5);
color:#fff;
border:none;
font-size:22px;
padding:10px 16px;
cursor:pointer;
z-index:5;
}

.slider-prev{
left:10px;
}

.slider-next{
right:10px;
}

.slider-dots{
position:absolute;
bottom:15px;
width:100%;
text-align:center;
}

.slider-dots span{
height:12px;
width:12px;
margin:0 4px;
background:#bbb;
display:inline-block;
border-radius:50%;
cursor:pointer;
}

.slider-dots .active{
background:#000;
}

</style>


<script>

document.addEventListener("DOMContentLoaded", function(){

let slides = document.querySelectorAll(".pro-slider .slide");
let next = document.querySelector(".slider-next");
let prev = document.querySelector(".slider-prev");
let dotsContainer = document.querySelector(".slider-dots");

let index = 0;

slides.forEach((slide,i)=>{
let dot=document.createElement("span");
dot.addEventListener("click",function(){
showSlide(i);
});
dotsContainer.appendChild(dot);
});

let dots=document.querySelectorAll(".slider-dots span");

function showSlide(i){

slides.forEach(s=>s.style.display="none");
dots.forEach(d=>d.classList.remove("active"));

slides[i].style.display="block";
dots[i].classList.add("active");

index=i;

}

function nextSlide(){
index++;
if(index>=slides.length){index=0;}
showSlide(index);
}

function prevSlide(){
index--;
if(index<0){index=slides.length-1;}
showSlide(index);
}

next.onclick=nextSlide;
prev.onclick=prevSlide;

showSlide(index);

setInterval(nextSlide,5000);

});

</script>


{% schema %}
{
"name":"Professional Slider",
"settings":[],
"blocks":[
{
"type":"slide",
"name":"Slide",
"settings":[
{
"type":"image_picker",
"id":"image",
"label":"Desktop Image"
},
{
"type":"image_picker",
"id":"mobile_image",
"label":"Mobile Image"
},
{
"type":"url",
"id":"link",
"label":"Slider Link"
}
]
}
],
"presets":[
{
"name":"Professional Slider"
}
]
}
{% endschema %}