{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'slider.js' | asset_url }}" defer="defer"></script>

<section class="slideshow-section section-{{ section.id }}-padding">
  <div class="slideshow page-width" id="Slideshow-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="slideshow__slide" {{ block.shopify_attributes }} data-index="{{ forloop.index0 }}">
        {%- if block.settings.image != blank -%}
          {%- assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round -%}
          {{ block.settings.image | image_url: width: 3840 | image_tag:
            loading: 'lazy',
            height: height,
            class: 'slideshow__image',
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg slideshow__image' }}
        {%- endif -%}

        <div class="slideshow__text-wrapper">
          {%- if block.settings.heading != blank -%}
            <h2 class="slideshow__heading">{{ block.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <p class="slideshow__subheading">{{ block.settings.subheading | escape }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.link }}" class="slideshow__button button">{{ block.settings.button_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="slideshow__controls">
    <button class="slideshow__arrow slideshow__arrow--prev" name="previous" aria-label="Previous slide" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    
    {%- if section.blocks.size > 1 -%}
      <div class="slideshow__dots">
        {%- for block in section.blocks -%}
          <button class="slideshow__dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}" type="button"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <button class="slideshow__arrow slideshow__arrow--next" name="next" aria-label="Next slide" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
</section>

{%- style -%}
  .slideshow-section {
    position: relative;
    overflow: hidden;
  }

  .slideshow {
    position: relative;
    width: 100%;
  }

  .slideshow__slide {
    display: none;
    position: relative;
  }

  .slideshow__slide:first-child {
    display: block;
  }

  .slideshow__image {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .slideshow__text-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: #fff;
    z-index: 2;
  }

  .slideshow__heading {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: inherit;
  }

  .slideshow__subheading {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: inherit;
  }

  .slideshow__button {
    background: #fff;
    color: #000;
    padding: 12px 24px;
    text-decoration: none;
    display: inline-block;
  }

  .slideshow__controls {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    z-index: 10;
  }

  .slideshow__arrow {
    background: rgba(0,0,0,0.5);
    border: none;
    color: #fff;
    padding: 12px;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slideshow__dots {
    display: flex;
    gap: 10px;
  }

  .slideshow__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: 2px solid #fff;
    cursor: pointer;
    padding: 0;
  }

  .slideshow__dot.active {
    background: #fff;
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const slider = document.getElementById('Slideshow-{{ section.id }}');
    if (!slider) return;
    
    const slides = slider.querySelectorAll('.slideshow__slide');
    const dots = slider.parentElement.querySelectorAll('.slideshow__dot');
    const prevBtn = slider.parentElement.querySelector('.slideshow__arrow--prev');
    const nextBtn = slider.parentElement.querySelector('.slideshow__arrow--next');
    
    let currentIndex = 0;
    const totalSlides = slides.length;
    let autoPlayInterval;

    function goToSlide(index) {
      slides.forEach(s => s.style.display = 'none');
      dots.forEach(d => d.classList.remove('active'));
      
      slides[index].style.display = 'block';
      dots[index].classList.add('active');
      currentIndex = index;
    }

    function nextSlide() {
      const next = (currentIndex + 1) % totalSlides;
      goToSlide(next);
    }

    function prevSlide() {
      const prev = (currentIndex - 1 + totalSlides) % totalSlides;
      goToSlide(prev);
    }

    if (prevBtn) prevBtn.addEventListener('click', function() {
      clearInterval(autoPlayInterval);
      prevSlide();
      startAutoPlay();
    });

    if (nextBtn) nextBtn.addEventListener('click', function() {
      clearInterval(autoPlayInterval);
      nextSlide();
      startAutoPlay();
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', function() {
        clearInterval(autoPlayInterval);
        goToSlide(index);
        startAutoPlay();
      });
    });

    function startAutoPlay() {
      autoPlayInterval = setInterval(nextSlide, 5000);
    }

    if (totalSlides > 1) {
      goToSlide(0);
      startAutoPlay();
    }
  });
</script>

{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
