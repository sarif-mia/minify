{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}

.section-{{ section.id }}-padding{
padding-top: {{ section.settings.padding_top }}px;
padding-bottom: {{ section.settings.padding_bottom }}px;
}

.collection-wrapper{
max-width: {{ section.settings.section_width }}px;
margin:0 auto;
}

.title-header{
display:flex;
align-items:center;
justify-content:space-between;
margin-bottom:30px;
gap:15px;
flex-wrap:wrap;
}

.view-all-btn{
text-decoration:none;
font-weight:600;
}

@media(max-width:750px){

.mobile-product-limit .grid__item:nth-child(n+{{ section.settings.products_to_show_mobile | plus:1 }}){
display:none;
}

}

{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">

<div class="collection section-{{ section.id }}-padding">

<div class="collection-wrapper">

<div class="title-header">

{% if section.settings.title != blank %}
<h2 class="title">{{ section.settings.title }}</h2>
{% endif %}

{% if section.settings.show_view_all and section.settings.collection %}
<a href="{{ section.settings.collection.url }}" class="view-all-btn">
View All
</a>
{% endif %}

</div>


<div class="grid mobile-product-limit grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down">

{% if section.settings.collection and section.settings.collection.products.size > 0 %}

{% for product in section.settings.collection.products limit: section.settings.products_to_show %}

<div class="grid__item">

{% render 'card-product',
card_product: product,
media_aspect_ratio: section.settings.image_ratio,
show_secondary_image: section.settings.show_secondary_image,
show_vendor: section.settings.show_vendor,
show_rating: section.settings.show_rating,
show_quick_add: section.settings.enable_quick_add
%}

</div>

{% endfor %}

{% endif %}

</div>

</div>

</div>

</div>


{% schema %}
{
"name": "Featured Collection Custom",
"tag": "section",
"class": "section",
"settings": [

{
"type": "collection",
"id": "collection",
"label": "Collection"
},

{
"type": "text",
"id": "title",
"default": "Featured Collection",
"label": "Heading"
},

{
"type": "range",
"id": "products_to_show",
"min": 2,
"max": 12,
"step": 1,
"default": 8,
"label": "Products on Desktop"
},

{
"type": "range",
"id": "products_to_show_mobile",
"min": 1,
"max": 6,
"step": 1,
"default": 2,
"label": "Products on Mobile"
},

{
"type": "range",
"id": "columns_desktop",
"min": 2,
"max": 5,
"step": 1,
"default": 4,
"label": "Desktop Columns"
},

{
"type": "select",
"id": "columns_mobile",
"default": "2",
"label": "Mobile Columns",
"options": [
{ "value": "1", "label": "1" },
{ "value": "2", "label": "2" }
]
},

{
"type": "range",
"id": "section_width",
"min": 900,
"max": 1600,
"step": 50,
"default": 1200,
"label": "Section Width"
},

{
"type": "checkbox",
"id": "show_view_all",
"default": true,
"label": "Show View All Button"
},

{
"type": "select",
"id": "image_ratio",
"options": [
{ "value": "adapt", "label": "Adapt to image" },
{ "value": "portrait", "label": "Portrait" },
{ "value": "square", "label": "Square" }
],
"default": "adapt",
"label": "Image Ratio"
},

{
"type": "checkbox",
"id": "show_secondary_image",
"default": true,
"label": "Show second image on hover"
},

{
"type": "checkbox",
"id": "show_vendor",
"default": false,
"label": "Show vendor"
},

{
"type": "checkbox",
"id": "show_rating",
"default": false,
"label": "Show product rating"
},

{
"type": "checkbox",
"id": "enable_quick_add",
"default": true,
"label": "Enable quick add"
},

{
"type": "color_scheme",
"id": "color_scheme",
"default": "scheme-1",
"label": "Color scheme"
},

{
"type": "range",
"id": "padding_top",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"label": "Padding Top"
},

{
"type": "range",
"id": "padding_bottom",
"min": 0,
"max": 100,
"step": 4,
"default": 40,
"label": "Padding Bottom"
}

],

"presets": [
{
"name": "Featured Collection"
}
]
}
{% endschema %}