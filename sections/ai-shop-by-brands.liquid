{% comment %}
AI-generated “Shop by Brands” section converted from a block.
This section supports:
- header & description
- grid or carousel layout with arrows/dots/both
- desktop/mobile logo sizes
- section width & padding
- logo/logo links up to 12 entries
- fully configurable colors, spacing, etc.
- accessible carousel implemented via custom element

This file restructures settings as section-level instead of block-level.
{% endcomment %}

{{ 'section-shop-by-brands.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ai-brand-section-{{ section.id }} {
    display: block;
    width: 100%;
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .ai-brand-container-{{ section.id }} {
    max-width: {{ section.settings.section_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-brand-header-{{ section.id }} {
    text-align: {{ section.settings.text_alignment }};
    margin-bottom: {{ section.settings.header_spacing }}px;
  }

  .ai-brand-heading-{{ section.id }} {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin }}px;
    font-weight: 600;
  }

  .ai-brand-text-{{ section.id }} {
    font-size: {{ section.settings.text_size }}px;
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-brand-logos-wrapper-{{ section.id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-brand-logos-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
    {% if section.settings.layout == 'carousel' %}display: none;{% endif %}
  }

  .ai-brand-logos-carousel-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.grid_gap }}px;
    transition: transform 0.5s ease;
    {% if section.settings.layout == 'grid' %}display: none;{% endif %}
  }

  .ai-brand-logo-item-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.logo_padding }}px;
    background-color: {{ section.settings.logo_background }};
    border-radius: {{ section.settings.logo_border_radius }}px;
    border: {{ section.settings.logo_border_width }}px solid {{ section.settings.logo_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    min-width: {% if section.settings.layout == 'carousel' %}calc((100% - ({{ section.settings.grid_gap }}px * {{ section.settings.columns_desktop | minus: 1 }})) / {{ section.settings.columns_desktop }}){% else %}auto{% endif %};
    flex-shrink: 0;
  }

  .ai-brand-logo-item-{{ section.id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-brand-logo-link-{{ section.id }} {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-brand-logo-image-{{ section.id }} {
    width: 100%;
    height: auto;
    max-width: {{ section.settings.logo_width_desktop }}px;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }

  .ai-brand-logo-placeholder-{{ section.id }} {
    width: 100%;
    max-width: {{ section.settings.logo_width_desktop }}px;
    margin: 0 auto;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 9;
  }

  .ai-brand-logo-placeholder-{{ section.id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-brand-carousel-controls-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 30px;
    {% if section.settings.layout == 'grid' %}display: none;{% endif %}
  }

  .ai-brand-carousel-button-{{ section.id }} {
    background-color: {{ section.settings.carousel_button_color }};
    color: {{ section.settings.carousel_button_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-brand-carousel-button-{{ section.id }}:hover {
    background-color: {{ section.settings.carousel_button_hover_color }};
    transform: scale(1.1);
  }

  .ai-brand-carousel-button-{{ section.id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-brand-carousel-button-{{ section.id }}:disabled:hover {
    transform: scale(1);
  }

  .ai-brand-carousel-dots-{{ section.id }} {
    display: flex;
    gap: 8px;
    {% if section.settings.carousel_navigation == 'arrows' %}display: none;{% endif %}
  }

  .ai-brand-carousel-dot-{{ section.id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ section.settings.carousel_dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    padding: 0;
  }

  .ai-brand-carousel-dot-{{ section.id }}.active {
    background-color: {{ section.settings.carousel_dot_active_color }};
    transform: scale(1.3);
  }

  .ai-brand-carousel-arrows-{{ section.id }} {
    display: flex;
    gap: 12px;
    {% if section.settings.carousel_navigation == 'dots' %}display: none;{% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-brand-logos-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }
    .ai-brand-logo-item-{{ section.id }} { min-width: {% if section.settings.layout == 'carousel' %}calc((100% - ({{ section.settings.grid_gap }}px * {{ section.settings.columns_mobile | minus: 1 }})) / {{ section.settings.columns_mobile }}){% else %}auto{% endif %}; }
    .ai-brand-logo-image-{{ section.id }} { max-width: {{ section.settings.logo_width_mobile }}px; }
    .ai-brand-logo-placeholder-{{ section.id }} { max-width: {{ section.settings.logo_width_mobile }}px; }
    .ai-brand-heading-{{ section.id }} { font-size: {{ section.settings.heading_size | times: 0.8 }}px; }
    .ai-brand-text-{{ section.id }} { font-size: {{ section.settings.text_size | times: 0.9 }}px; }
  }
{% endstyle %}

<div class="ai-brand-section-{{ section.id }}">
  <div class="ai-brand-container-{{ section.id }}">
    {% if section.settings.heading or section.settings.description %}
      <div class="ai-brand-header-{{ section.id }}">
        {% if section.settings.heading %}
          <h2 class="ai-brand-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description %}
          <div class="ai-brand-text-{{ section.id }}">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-brand-logos-wrapper-{{ section.id }}">
      <div class="ai-brand-logos-grid-{{ section.id }}">
        {% for i in (1..12) %}
          {% assign logo_key = 'brand_logo_' | append: i %}
          {% assign link_key = 'brand_link_' | append: i %}
          {% assign logo = section.settings[logo_key] %}
          {% assign link = section.settings[link_key] %}
          {% if logo != blank or link != blank %}
            <div class="ai-brand-logo-item-{{ section.id }}">
              {% if link %}
                <a href="{{ link }}" class="ai-brand-logo-link-{{ section.id }}" aria-label="Brand {{ i }}">
              {% endif %}
              {% if logo %}
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ logo.alt | escape }}"
                  class="ai-brand-logo-image-{{ section.id }}"
                  loading="lazy"
                  width="{{ logo.width }}"
                  height="{{ logo.height }}"
                >
              {% else %}
                <div class="ai-brand-logo-placeholder-{{ section.id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
              {% if link %}</a>{% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="ai-brand-logos-carousel-{{ section.id }}" data-carousel>
        {% for i in (1..12) %}
          {% assign logo_key = 'brand_logo_' | append: i %}
          {% assign link_key = 'brand_link_' | append: i %}
          {% assign logo = section.settings[logo_key] %}
          {% assign link = section.settings[link_key] %}
          {% if logo != blank or link != blank %}
            <div class="ai-brand-logo-item-{{ section.id }}">
              {% if link %}
                <a href="{{ link }}" class="ai-brand-logo-link-{{ section.id }}" aria-label="Brand {{ i }}">
              {% endif %}
              {% if logo %}
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ logo.alt | escape }}"
                  class="ai-brand-logo-image-{{ section.id }}"
                  loading="lazy"
                  width="{{ logo.width }}"
                  height="{{ logo.height }}"
                >
              {% else %}
                <div class="ai-brand-logo-placeholder-{{ section.id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
              {% if link %}</a>{% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-brand-carousel-controls-{{ section.id }}">
      <div class="ai-brand-carousel-arrows-{{ section.id }}">
        <button
          class="ai-brand-carousel-button-{{ section.id }}"
          data-prev
          aria-label="Previous slide"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          class="ai-brand-carousel-button-{{ section.id }}"
          data-next
          aria-label="Next slide"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
      <div class="ai-brand-carousel-dots-{{ section.id }}" data-dots></div>
    </div>
  </div>
</div>

<script>
  (function() {
    class BrandCarousel{{ section.id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.itemsPerPage = {{ section.settings.columns_desktop }};
        this.itemsPerPageMobile = {{ section.settings.columns_mobile | default: 2 }};
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        if (!this.carousel) return;

        this.items = Array.from(this.carousel.children);
        this.totalItems = this.items.length;

        this.updateItemsPerPage();
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();

        window.addEventListener('resize', () => {
          this.updateItemsPerPage();
          this.createDots();
          this.updateCarousel();
        });
      }

      updateItemsPerPage() {
        this.itemsPerPage = window.innerWidth <= 749 
          ? this.itemsPerPageMobile 
          : {{ section.settings.columns_desktop }};
        this.totalPages = Math.ceil(this.totalItems / this.itemsPerPage);
      }

      setupEventListeners() {
        if (this.prevButton) { this.prevButton.addEventListener('click', () => this.prev()); }
        if (this.nextButton) { this.nextButton.addEventListener('click', () => this.next()); }
      }

      createDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.totalPages; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-brand-carousel-dot-{{ section.id }}';
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === this.currentIndex) { dot.classList.add('active'); }
          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      updateCarousel() {
        const offset = -this.currentIndex * 100;
        this.carousel.style.transform = `translateX(${offset}%)`;
        if (this.prevButton) { this.prevButton.disabled = this.currentIndex === 0; }
        if (this.nextButton) { this.nextButton.disabled = this.currentIndex >= this.totalPages - 1; }
        const dots = this.dotsContainer?.querySelectorAll('.ai-brand-carousel-dot-{{ section.id }}');
        if (dots) {
          dots.forEach((dot, index) => {
            index === this.currentIndex ? dot.classList.add('active') : dot.classList.remove('active');
          });
        }
      }

      prev() { if (this.currentIndex > 0) { this.currentIndex--; this.updateCarousel(); } }
      next() { if (this.currentIndex < this.totalPages - 1) { this.currentIndex++; this.updateCarousel(); } }
    }

    customElements.define('brand-carousel-{{ section.id }}', BrandCarousel{{ section.id }});
  })();
</script>

